{
  "layer": "bottom",
  "position": "top",
  "height": 29,
  "spacing": 2,
  "exclusive": true,
  "gtk-layer-shell": true,
  "passthrough": false,
  "fixed-center": true,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["hyprland/window"],
  "modules-right": [
    "cpu",
    "memory",
    "backlight",
    "battery",
    "pulseaudio",
    "clock",
    "tray",
    "group/powermenu"
  ],
  "hyprland/workspaces": {
    "format": "{id}",
    "all-outputs": true,
    "disable-scroll": false,
    "active-only": false,
    "on-click": "activate"
  },
  "hyprland/window": {
    "format": "у°–Ї {title}",
    "max-length": 40
  },
  "tray": {
    "show-passive-items": true,
    "spacing": 10
  },
  "clock": {
    "format": "{:%I:%M %p}",
    "rotate": 0,
    "format-alt": "{п„і  %dВ·%mВ·%y}",
    "tooltip-format": "<span>{calendar}</span>",
    "calendar": {
      "mode": "month",
      "format": {
        "months": "<span color='#ff6699'><b>{}</b></span>",
        "days": "<span color='#cdd6f4'><b>{}</b></span>",
        "weekdays": "<span color='#7CD37C'><b>{}</b></span>",
        "today": "<span color='#ffcc66'><b>{}</b></span>"
      }
    }
  },
  "cpu": {
    "format": "п‹› {usage}%",
    "tooltip": true,
    "interval": 1,
    "on-click": "kitty --class btop -e btop"
  },
  "memory": {
    "format": "ої… {used:0.1f}Gi",
    "on-click": "kitty --class btop -e btop"
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"],
    "on-scroll-up": "brightnessctl set +1%",
    "on-scroll-down": "brightnessctl set 1%-"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "п‘¦  Muted",
    "format-icons": {
      "headphone": "пЂҐ",
      "default": ["пЂ¦ ", "пЂ§ ", "пЂЁ "]
    },
    "on-click": "pavucontrol"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "у±ђ‹ {capacity}%",
    "format-plugged": "п‡¦ {capacity}%",
    "format-alt": "{time} {icon}",
    "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
  },
  "group/powermenu": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-power",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/power",
      "custom/lock",
      "custom/suspend",
      "custom/reboot",
      "custom/quit"
    ]
  },
  "custom/power": {
    "format": "вЏ»",
    "tooltip": false
  },
  "custom/lock": {
    "format": "пЂЈ",
    "tooltip-format": "Bloquear",
    "on-click": "hyprlock"
  },
  "custom/suspend": {
    "format": "у°¤„",
    "tooltip-format": "Suspender",
    "on-click": "systemctl suspend"
  },
  "custom/reboot": {
    "format": "у°њ‰",
    "tooltip-format": "Reiniciar",
    "on-click": "systemctl reboot"
  },
  "custom/quit": {
    "format": "у°€†",
    "tooltip-format": "Apagar",
    "on-click": "systemctl poweroff"
  }
}
